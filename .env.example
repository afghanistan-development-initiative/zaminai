# ── ZaminAI environment variables ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to git.

# Google Earth Engine service account (from GEE console)
GEE_SERVICE_ACCOUNT=zaminai@your-project.iam.gserviceaccount.com

# GEE private key — paste the full JSON key content as a single line,
# replacing real newlines with the two-character sequence \n
# e.g.  -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
GEE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nPASTE_KEY_HERE\n-----END RSA PRIVATE KEY-----

# Google Gemini (AI answers in Dari/Pashto/English)
GEMINI_API_KEY=AIza...

# Anthropic Claude (photo diagnosis, farmer onboarding chat)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (farmer profiles, saved fields, analysis history, conversations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGci...

# Server port (optional — defaults to 5000 for Flask, 8000 for FastAPI)
# PORT=5000
